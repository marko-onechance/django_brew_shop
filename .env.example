# Copy to .env and fill in. .env is in .gitignore and never committed.

DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Local PostgreSQL (matches docker-compose defaults)
DATABASE_NAME=myshop_db
DATABASE_USER=myshop_user
DATABASE_PASSWORD=myshop_password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# On Render, DATABASE_URL is set automatically from the linked database.
# Locally you can also use: DATABASE_URL=postgres://myshop_user:myshop_password@localhost:5432/myshop_db

# Email — console backend for local dev (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@hopandbarley.com
# For real SMTP delivery:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Demo admin credentials (used by create_demo_admin management command)
DEMO_ADMIN_USER=admin
DEMO_ADMIN_PASSWORD=admin1234
DEMO_ADMIN_EMAIL=admin@hopandbarley.demo
